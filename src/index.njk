---
layout: layouts/base.njk
title: Blog
---
<section class="home-layout">
  <div class="home-feed">
    <ul class="post-list">
    {%- for post in collections.post | reverse -%}
      <li class="post-card">
        {% if post.data.image %}
        <a href="{{ post.url }}" class="card-image-link" aria-label="{{ post.data.title }}">
          <img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" class="card-image">
        </a>
        {% endif %}
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <div class="post-meta">
          {{ post.date | date("%B %d, %Y") }} &middot; {{ post.content | readingTime }}
        </div>
        {% if post.data.description %}
          <p class="post-description">{{ post.data.description }}</p>
        {% endif %}
        {% if post.data.tags %}
        <div class="tags">
          {% for tag in post.data.tags %}
            {% if tag != "post" %}
              <a href="/tags/{{ tag }}/" class="tag">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </li>
    {%- endfor -%}
    </ul>
  </div>

  <aside class="timeline-panel" aria-label="Post timeline">
    <div class="timeline-header">
      <h2>History</h2>
    </div>

    <div class="timeline">
      {% for year in collections.post | timelineArchive %}
      <details class="timeline-year" {% if year.defaultOpen %}open{% endif %}>
        <summary class="timeline-summary timeline-summary-year">
          <span class="timeline-summary-title">{{ year.year }}</span>
          <span class="timeline-summary-meta">{{ year.monthCount }} month{% if year.monthCount != 1 %}s{% endif %} &middot; {{ year.postCount }} post{% if year.postCount != 1 %}s{% endif %}</span>
        </summary>

        <div class="timeline-months">
          {% for month in year.months %}
          <details class="timeline-month" {% if month.defaultOpen %}open{% endif %}>
            <summary class="timeline-summary timeline-summary-month">
              <span class="timeline-summary-title">{{ month.label }}</span>
              <span class="timeline-summary-meta">{{ month.postCount }} post{% if month.postCount != 1 %}s{% endif %}</span>
            </summary>

            <ul class="timeline-posts">
              {% for post in month.posts %}
              <li class="timeline-post">
                <a href="{{ post.url }}">{{ post.data.title }}</a>
              </li>
              {% endfor %}
            </ul>
          </details>
          {% endfor %}
        </div>
      </details>
      {% endfor %}
    </div>
  </aside>
</section>
