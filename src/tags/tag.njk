---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /tags/{{ tag }}/
layout: layouts/base.njk
---
<h1>Posts tagged: {{ tag }}</h1>

<ul class="post-list" style="margin-top: 2rem;">
  {% set taggedPosts = collections[tag] %}
  {% for post in taggedPosts | reverse %}
  <li class="post-card">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>

    <div class="post-meta">
      <span>{{ post.date | date("MMMM dd, yyyy") }}</span>
      <span>{{ post.content | readingTime }}</span>
    </div>

    {% if post.data.description %}
    <p class="post-description">{{ post.data.description }}</p>
    {% endif %}

    {% if post.data.tags %}
    <ul class="tag-list">
      {% for t in post.data.tags %}
        {% if t !== "post" %}
        <li><a href="/tags/{{ t }}/" class="tag-pill">{{ t }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
    {% endif %}
  </li>
  {% endfor %}
</ul>
