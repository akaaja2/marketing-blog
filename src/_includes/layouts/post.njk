---
layout: layouts/base.njk
---
{% if image %}
<img src="{{ image }}" alt="{{ imageAlt or title }}" class="post-hero">
{% endif %}
<div id="progress-bar" style="position:fixed;top:0;left:0;height:3px;width:0%;background:#2563eb;z-index:100;transition:width 0.1s linear;"></div>
<article>
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      {{ date | date("%B %d, %Y") }} &middot; {{ content | readingTime }}
    </div>
    {% if tags %}
    <div class="tags">
      {% for tag in tags %}
        {% if tag != "post" %}
          <a href="/tags/{{ tag }}/" class="tag">{{ tag }}</a>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>

  {% if showCarousel and carouselSlides %}
    {% include "components/carousel-mockup.njk" %}
  {% endif %}

  {% set related = collections.post | relatedPosts(tags, page.url) %}
  {% if related.length %}
  <div class="related-posts">
    <h3>Related posts</h3>
    <ul class="post-list" style="margin-top: 16px;">
      {% for post in related %}
      <li class="post-card" style="padding: 20px 0;">
        <h4 style="font-size: 18px; margin: 0 0 6px;">
          <a href="{{ post.url }}" style="color: var(--text);">
            {{ post.data.title }}
          </a>
        </h4>
        <div class="post-meta">
          {{ post.date | date("%B %d, %Y") }}
          &middot; {{ post.content | readingTime }}
        </div>
        {% if post.data.description %}
        <p class="post-description">{{ post.data.description }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  {% if downloadable %}
  <div class="share-section" style="padding-bottom: 0;">
    <div class="share-links">
      <a href="/downloads/{{ page.filePathStem | replace("/posts/", "") }}.md" download>Download .md</a>
    </div>
  </div>
  {% endif %}
  <div class="reactions" data-slug="{{ page.fileSlug }}">
    <p class="reactions-label">Found this useful?</p>
    <div class="reaction-buttons">
      <button class="reaction-btn" data-emoji="👍"><span class="reaction-emoji">👍</span><span class="reaction-count" data-for="👍">·</span></button>
      <button class="reaction-btn" data-emoji="💡"><span class="reaction-emoji">💡</span><span class="reaction-count" data-for="💡">·</span></button>
      <button class="reaction-btn" data-emoji="🔥"><span class="reaction-emoji">🔥</span><span class="reaction-count" data-for="🔥">·</span></button>
    </div>
  </div>

  <div class="share-section">
    <p>Share this post</p>
    <div class="share-links">
      <a href="https://twitter.com/intent/tweet?url=https://claude4marketing.netlify.app{{ page.url }}&text={{ title | urlencode }}" target="_blank" rel="noopener">Twitter / X</a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://claude4marketing.netlify.app{{ page.url }}" target="_blank" rel="noopener">LinkedIn</a>
      <a href="#" onclick="navigator.clipboard.writeText(window.location.href);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy link',2000);return false;">Copy link</a>
    </div>
  </div>
</article>
<script>
  window.addEventListener('scroll', () => {
    const el = document.getElementById('progress-bar');
    const doc = document.documentElement;
    el.style.width = (doc.scrollTop / (doc.scrollHeight - doc.clientHeight) * 100) + '%';
  });

  // Syntax highlighting
  Prism.highlightAll();

  document.querySelectorAll('.post-content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(pre.querySelector('code') ? pre.querySelector('code').innerText : pre.innerText).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });
    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>
<script src="https://cdn.jsdelivr.net/npm/prismjs@1/prism.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/prismjs@1/plugins/autoloader/prism-autoloader.min.js"></script>
<script>
  Prism.plugins.autoloader.languages_path = 'https://cdn.jsdelivr.net/npm/prismjs@1/components/';
</script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
  const _sb = window.supabase.createClient(
    'https://ituxogklmxagixcoclek.supabase.co',
    'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml0dXhvZ2tsbXhhZ2l4Y29jbGVrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM3NTM3MjksImV4cCI6MjA4OTMyOTcyOX0.udb9c8bEB-RR981tgj1wbRdJGeh0SsQ9bOiFNxKJtl0'
  );
  const _reactionEl = document.querySelector('.reactions');
  const _slug = _reactionEl && _reactionEl.dataset.slug;
  const _emojis = ['👍','💡','🔥'];

  async function _loadCounts() {
    const { data } = await _sb.from('post_reactions').select('emoji,count').eq('post_slug', _slug);
    _emojis.forEach(e => {
      const row = data && data.find(r => r.emoji === e);
      const el = _reactionEl.querySelector(`.reaction-count[data-for="${e}"]`);
      if (el) el.textContent = row ? row.count : '0';
    });
  }

  _reactionEl && _reactionEl.querySelectorAll('.reaction-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (btn.classList.contains('reacted')) return;
      btn.classList.add('reacted');
      const emoji = btn.dataset.emoji;
      const { data } = await _sb.rpc('increment_reaction', { p_slug: _slug, p_emoji: emoji });
      const el = btn.querySelector('.reaction-count');
      if (el && data !== null) el.textContent = data;
    });
  });

  if (_slug) _loadCounts();
</script>
